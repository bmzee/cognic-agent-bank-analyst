# Build outputs (Model Y: the wheel + attestation bundle + the AgentCard
# JWS are release assets regenerated by `agentos sign`, not
# source-controlled). agent_cards/agent-card.json IS source — it is the
# payload `agentos sign --bundle` signs into the detached JWS at release.
dist/
attestations/*
!attestations/.gitkeep
agent_cards/agent-card.jws

# Environments + caches
.venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/

# uv.lock is committed: release evidence must resolve from the public tree.
